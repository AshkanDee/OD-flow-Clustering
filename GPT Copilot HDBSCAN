def knee_elbow(d_sorted: np.ndarray):
    """
    R version returns the distance value at max perpendicular distance
    to the line from first to last point (classic knee on sorted curve).
    """
    d = np.asarray(d_sorted, dtype=float)
    n = d.size
    if n < 10:
        return np.nan

    x = np.arange(1, n + 1, dtype=float)  # 1..n like R
    x1, y1 = 1.0, d[0]
    x2, y2 = float(n), d[-1]

    num = np.abs((y2 - y1) * x - (x2 - x1) * d + x2 * y1 - y2 * x1)
    den = np.sqrt((y2 - y1) ** 2 + (x2 - x1) ** 2)
    dist = num / den

    return d[int(np.argmax(dist))]

def knn_distances(X_scaled: np.ndarray, k: int):
    """
    Returns vector of kNN distances (distance to kth neighbor) for each point.
    Matches dbscan::kNNdist(X_scaled, k=k) conceptually.
    """
    # We ask for k+1 because the closest neighbor is the point itself (distance 0).
    nbrs = NearestNeighbors(n_neighbors=k + 1, algorithm="auto", metric="euclidean")
    nbrs.fit(X_scaled)
    dists, _ = nbrs.kneighbors(X_scaled, return_distance=True)
    # kth neighbor distance: index k (0=self, 1=1st neighbor, ..., k=kth neighbor)
    return dists[:, k]

def knn_summary_one(X_scaled: np.ndarray, k: int,
                    q=(0.01, 0.05, 0.10, 0.25, 0.50, 0.75, 0.90, 0.95, 0.99)):
    d = knn_distances(X_scaled, k=k)
    ds = np.sort(d)

    out = {
        "k": k,
        "n": int(d.size),
        "elbow_eps": float(knee_elbow(ds)),
    }

    qs = np.quantile(d, q=q)
    for p, val in zip(q, qs):
        out[f"q{int(round(p*100)):02d}"] = float(val)

    return out

def snn_sharednn_diagnostics(X_scaled: np.ndarray, k: int = 30,
                            n_probe: int = 4000, seed: int = 1):
    """
    Roughly reproduces your R approach:
    - sample up to n_probe points
    - compute kNN ids for all points
    - repeatedly sample pairs inside probe and compute shared neighbor counts
    """
    rng = np.random.default_rng(seed)
    n = X_scaled.shape[0]
    idx = rng.choice(n, size=min(n, n_probe), replace=False)

    nbrs = NearestNeighbors(n_neighbors=k + 1, metric="euclidean").fit(X_scaled)
    _, ids = nbrs.kneighbors(X_scaled, return_distance=True)
    # drop self neighbor
    ids = ids[:, 1:(k + 1)]

    # neighbor lists for probe indices
    nn_list = [set(ids[i, :].tolist()) for i in idx]

    m = len(nn_list)
    checks = min(8000, m * 2)

    shared_counts = np.empty(checks, dtype=int)
    for t in range(checks):
        a = rng.integers(0, m)
        b = rng.integers(0, m)
        shared_counts[t] = len(nn_list[a].intersection(nn_list[b]))

    return {
        "k": int(k),
        "probe_n": int(m),
        "shared_mean": float(shared_counts.mean()),
        "shared_median": float(np.median(shared_counts)),
        "shared_q90": float(np.quantile(shared_counts, 0.90)),
        "shared_q95": float(np.quantile(shared_counts, 0.95)),
        "shared_q99": float(np.quantile(shared_counts, 0.99)),
    }

def hdbscan_mcs_candidates(N_eff: int, n: int = 14, frac_min: float = 0.005, frac_max: float = 0.10):
    """
    Same as your R:
    - compute min_cluster_size candidates as log-spaced ints
      between frac_min*N_eff and frac_max*N_eff
    """
    lo = max(10, int(round(frac_min * N_eff)))
    hi = max(lo + 1, int(round(frac_max * N_eff)))

    vals = np.unique(np.round(np.exp(np.linspace(np.log(lo), np.log(hi), num=n))).astype(int))
    return np.sort(vals)

