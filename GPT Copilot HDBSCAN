def snap_scalar(v, allowed):
    allowed = np.asarray(allowed, dtype=int)
    v = int(np.round(v))
    return int(allowed[np.argmin(np.abs(allowed - v))])

def mcs_allowed_from_subsample(N_eff, n=14, frac_min=0.005, frac_max=0.10):
    lo = max(10, int(round(frac_min * N_eff)))
    hi = max(lo + 1, int(round(frac_max * N_eff)))
    vals = np.unique(np.round(np.exp(np.linspace(np.log(lo), np.log(hi), n))).astype(int))
    return vals.tolist()


# ==========================================================
# (B) Objective: evaluate HDBSCAN params -> (f1,f2) to MINIMIZE
#     Uses YOUR Step 12 eval_solution() + Step 11 cohesion function.
# ==========================================================

def eval_hdbscan_params(min_cluster_size, min_samples, X_scaled, u_trips,
                        min_cluster_size_for_cohesion=2,
                        cohesion_floor=None,
                        cluster_selection_method="eom",
                        core_dist_n_jobs=1):
    """
    Returns np.array([f1_neg_coverage, f2_neg_dir_cohesion]) to MINIMIZE
    - f1 = -coverage
    - f2 = -dir_cohesion

    Important:
    - We map HDBSCAN labels (-1 noise, 0..K-1 clusters) -> DBSCAN-style (0 noise, 1..K)
      so that eval_solution(noise_label=0) remains consistent everywhere.
    """

    clusterer = hdbscan.HDBSCAN(
        min_cluster_size=int(min_cluster_size),
        min_samples=int(min_samples),
        metric="euclidean",
        cluster_selection_method=cluster_selection_method,
        core_dist_n_jobs=int(core_dist_n_jobs)
    )

    labels = clusterer.fit_predict(X_scaled).astype(int)  # -1 noise

    # Map to DBSCAN-style for eval_solution consistency:
    labels_dbscan_style = np.where(labels == -1, 0, labels + 1)

    res = eval_solution(
        labels=labels_dbscan_style,
        u_trips=u_trips,
        noise_label=0,
        min_cluster_size=int(min_cluster_size_for_cohesion)
    )

    # Optional soft filter: remove "directionless" solutions
    if cohesion_floor is not None:
        if (not np.isfinite(res["dir_cohesion"])) or (res["dir_cohesion"] < float(cohesion_floor)):
            return np.array([1.0, 1.0], dtype=float)

    return np.array([res["f1_neg_coverage"], res["f2_neg_dir_cohesion"]], dtype=float)


# ==========================================================
# (C) Cached objective per city + snapping to allowed grids
# ==========================================================

def make_objfun_city_cached(city_id, data_for_opt, trip_dirs_for_opt,
                            mcs_allowed, ms_allowed,
                            min_cluster_size_for_cohesion=2,
                            cohesion_floor=None,
                            cluster_selection_method="eom",
                            core_dist_n_jobs=1):

    X_scaled = data_for_opt[city_id]["X_scaled"]
    u_trips  = trip_dirs_for_opt[city_id]

    if X_scaled.shape[0] != np.asarray(u_trips).shape[0]:
        raise ValueError(f"{city_id}: X_scaled rows != trip_dirs rows")

    cache = {}

    mcs_allowed = np.asarray(mcs_allowed, dtype=int)
    ms_allowed  = np.asarray(ms_allowed, dtype=int)

    def objfun(x):
        # snap to allowed grids
        mcs = snap_scalar(x[0], mcs_allowed)
        ms  = snap_scalar(x[1], ms_allowed)

        key = (int(mcs), int(ms))
        if key in cache:
            return cache[key]

        val = eval_hdbscan_params(
            min_cluster_size=mcs,
            min_samples=ms,
            X_scaled=X_scaled,
            u_trips=u_trips,
            min_cluster_size_for_cohesion=min_cluster_size_for_cohesion,
            cohesion_floor=cohesion_floor,
            cluster_selection_method=cluster_selection_method,
            core_dist_n_jobs=core_dist_n_jobs
        )
        cache[key] = val
        return val

    info = {
        "mcs_allowed": mcs_allowed.tolist(),
        "ms_allowed": ms_allowed.tolist(),
        "mcs_min": int(mcs_allowed.min()),
        "mcs_max": int(mcs_allowed.max()),
        "ms_min": int(ms_allowed.min()),
        "ms_max": int(ms_allowed.max()),
        "N_eff": int(X_scaled.shape[0]),
    }
    return objfun, info


