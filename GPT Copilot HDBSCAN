def get_hdbscan_selected_params(preferred="knee_full"):
    out = {}

    for city_id in prepared_plot.keys():

        # 1) knee_full_hdb from Step 15 (preferred)
        if preferred == "knee_full" and "knee_full_hdb" in globals():
            kfh = knee_full_hdb
            if isinstance(kfh, pd.DataFrame) and len(kfh) > 0:
                row = kfh[kfh["city"] == city_id].head(1)
                if len(row) == 1:
                    out[city_id] = {
                        "min_cluster_size": int(row["min_cluster_size"].iloc[0]),
                        "min_samples": int(row["min_samples"].iloc[0]),
                    }
                    continue

        # 1b) fallback: knee_solutions_hdb from Step 14 (subsample knee)
        if preferred == "knee_full" and "knee_solutions_hdb" in globals():
            knee = knee_solutions_hdb.get(city_id, None)
            if isinstance(knee, pd.DataFrame) and len(knee) > 0:
                out[city_id] = {
                    "min_cluster_size": int(knee["min_cluster_size"].iloc[0]),
                    "min_samples": int(knee["min_samples"].iloc[0]),
                }
                continue

        # 2) expert fallback: hdbscan_params (minPts) + MIN_CLUSTER_SIZE_FIXED
        if "hdbscan_params" in globals() and city_id in hdbscan_params:
            mcs = int(MIN_CLUSTER_SIZE_FIXED) if "MIN_CLUSTER_SIZE_FIXED" in globals() else 20
            out[city_id] = {
                "min_cluster_size": mcs,
                "min_samples": int(hdbscan_params[city_id]["minPts"]),
            }
            continue

        raise ValueError(
            f"[HDBSCAN] No selected parameters found for city: {city_id}. "
            "Need knee_full_hdb/knee_solutions_hdb or hdbscan_params."
        )

    return out


# ------------------------------------------------------------
# Plot function: top-N clusters only (fast with LineCollection)
# ------------------------------------------------------------

def plot_flow_topN_clean_py(city_id,
                            prepared,
                            labels_dbscan_style,
                            algo_name="HDBSCAN",
                            noise_label=0,
                            out_dir="plots_flows_top3",
                            top_n_clusters=3,
                            sample_n_segments_top=25000,
                            seed=1,
                            show_plot=True):

    os.makedirs(out_dir, exist_ok=True)

    df = prepared[city_id]["city_clean"]
    req = ["x_o", "y_o", "x_d", "y_d"]
    missing = [c for c in req if c not in df.columns]
    if missing:
        raise ValueError(f"{city_id}: Missing columns in city_clean: {missing}")

    labels = np.asarray(labels_dbscan_style, dtype=int)
    if labels.shape[0] != df.shape[0]:
        raise ValueError(
            f"{city_id}: labels length != nrow(city_clean) | labels={labels.shape[0]} rows={df.shape[0]}"
        )

    # compute top clusters by size excluding noise
    cl = labels
    cl_nonnoise = cl[(cl != noise_label) & np.isfinite(cl)]
    if cl_nonnoise.size == 0:
        print(f"WARNING: No non-noise clusters for {city_id} ({algo_name}).")
        return None

    uniq, cnt = np.unique(cl_nonnoise, return_counts=True)
    order = np.argsort(-cnt)
    top_ids = uniq[order][:top_n_clusters].astype(int)

    # filter to top clusters
    mask_top = np.isin(cl, top_ids)
    df_top = df.loc[mask_top, ["x_o", "y_o", "x_d", "y_d"]].copy()
    cl_top = cl[mask_top]

    # sample segments for readability
    rng = np.random.default_rng(seed)
    n_top = df_top.shape[0]
    if n_top > sample_n_segments_top:
        idx = rng.choice(n_top, size=sample_n_segments_top, replace=False)
        df_top = df_top.iloc[idx, :]
        cl_top = cl_top[idx]

    # build line segments (N,2,2)
    segs = np.stack(
        [df_top[["x_o", "y_o"]].to_numpy(dtype=float),
         df_top[["x_d", "y_d"]].to_numpy(dtype=float)],
        axis=1
    )

    # map cluster -> 0..(top_n-1) for colors (let matplotlib choose automatically)
    top_ids_list = top_ids.tolist()
    cl_idx = np.array([top_ids_list.index(int(c)) for c in cl_top], dtype=int)

    fig, ax = plt.subplots(figsize=(9, 7.5))
    lc = LineCollection(segs, linewidths=0.30, alpha=0.28)
    lc.set_array(cl_idx)  # colormap indices
    ax.add_collection(lc)

    ax.set_aspect("equal", adjustable="box")
    ax.set_title(f"{algo_name} — Top {top_n_clusters} clusters — {city_id.upper()}", fontweight="bold")
    ax.set_xlabel("UTM Easting (m)")
    ax.set_ylabel("UTM Northing (m)")
    ax.autoscale()

    # colorbar with cluster ids
    cbar = fig.colorbar(lc, ax=ax, fraction=0.035, pad=0.02)
    cbar.set_label("Cluster (top-N)")
    # tick labels: show actual cluster ids
    cbar.set_ticks(np.arange(len(top_ids)))
    cbar.set_ticklabels([str(int(x)) for x in top_ids])

    ax.grid(True, alpha=0.25)

    f_out = os.path.join(out_dir, f"flows_{algo_name}_{city_id}_top{top_n_clusters}.png")
    plt.savefig(f_out, dpi=300, bbox_inches="tight")

    if show_plot:
        plt.show()
    plt.close(fig)

    return {"file": f_out, "top_cluster_ids": top_ids.tolist()}


