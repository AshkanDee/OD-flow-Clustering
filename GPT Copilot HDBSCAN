def make_X_and_clean(city_df: pd.DataFrame, feature_cols=("x_o", "y_o", "dx", "dy")):
    """
    Mirror of R make_X_and_clean():
    - build X from feature cols
    - ok = complete cases
    - X_scaled = scale(X[ok,])
    - city_clean = city_df[ok,]
    """

    missing = [c for c in feature_cols if c not in city_df.columns]
    if missing:
        raise ValueError(f"Missing required columns: {', '.join(missing)}")

    X = city_df.loc[:, feature_cols].to_numpy()

    # complete.cases equivalent
    ok = np.isfinite(X).all(axis=1)

    X_ok = X[ok, :]
    # scale() equivalent: (x - mean) / sd, columnwise with ddof=1 (R uses sample sd)
    mu = X_ok.mean(axis=0)
    sd = X_ok.std(axis=0, ddof=1)
    # avoid divide-by-zero if any feature constant
    sd_safe = np.where(sd == 0, 1.0, sd)
    X_scaled = (X_ok - mu) / sd_safe

    city_clean = city_df.loc[ok, :].copy()

    return {"X": X_ok, "ok": ok, "X_scaled": X_scaled, "city_clean": city_clean}


