# Run plots for all cities using selected HDBSCAN params
# ------------------------------------------------------------

selected_params_hdb = get_hdbscan_selected_params(preferred="knee_full")

for city_id in prepared_plot.keys():

    p = selected_params_hdb[city_id]
    X = prepared_plot[city_id]["X_scaled"]

    clusterer = hdbscan.HDBSCAN(
        min_cluster_size=int(p["min_cluster_size"]),
        min_samples=int(p["min_samples"]),
        metric="euclidean",
        cluster_selection_method="eom",
        core_dist_n_jobs=1
    )

    labels = clusterer.fit_predict(X).astype(int)  # -1 noise
    labels_dbscan_style = np.where(labels == -1, 0, labels + 1)

    out = plot_flow_topN_clean_py(
        city_id=city_id,
        prepared=prepared_plot,
        labels_dbscan_style=labels_dbscan_style,
        algo_name="HDBSCAN",
        noise_label=0,
        out_dir="plots_flows_top3",
        top_n_clusters=3,
        sample_n_segments_top=25000,
        seed=1,
        show_plot=True
    )

    if out is not None:
        print(f"{city_id} | saved:", out["file"], "| top clusters:", out["top_cluster_ids"])
