# Step 16 — Hypervolume analysis for Pareto fronts (coverage + cohesion) [PYTHON]
# - Works for multiple algorithms (e.g., DBSCAN + SNN + HDBSCAN)
# - Uses columns: coverage, dir_cohesion
# - Global normalization across ALL cities AND ALL algorithms
# - Converts to MIN space: f1 = 1 - coverage_norm, f2 = 1 - cohesion_norm
# ------------------------------------------------------------

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt


# -----------------------------
# Non-dominated filter for MINIMIZATION
# -----------------------------
def nondominated_min(F: np.ndarray) -> np.ndarray:
    """
    Keep rows not dominated in minimization:
    j dominates i if all(F[j] <= F[i]) and any(F[j] < F[i])
    """
    F = np.asarray(F, dtype=float)
    n = F.shape[0]
    if n == 0:
        return F

    keep = np.ones(n, dtype=bool)
    for i in range(n):
        if not keep[i]:
            continue
        for j in range(n):
            if i == j or not keep[i]:
                continue
            if np.all(F[j, :] <= F[i, :]) and np.any(F[j, :] < F[i, :]):
                keep[i] = False
    return F[keep, :]


# -----------------------------
# Exact 2D dominated hypervolume for MINIMIZATION
# -----------------------------
def hv2d_min(F: np.ndarray, ref: np.ndarray) -> float:
    """
    2D hypervolume for minimization, dominated area between points and ref.
    Assumes smaller is better; ref is a "worse" point (larger coordinates).
    """
    F = np.asarray(F, dtype=float)
    ref = np.asarray(ref, dtype=float)

    if F.shape[0] == 0:
        return 0.0

    F = nondominated_min(F)

    # sort by f1 then f2 (like your R order)
    order = np.lexsort((F[:, 1], F[:, 0]))
    F = F[order, :]

    hv = 0.0
    h = float(ref[1])
    for i in range(F.shape[0]):
        f1 = float(F[i, 0])
        f2 = float(F[i, 1])
        if f2 < h:
            hv += (float(ref[0]) - f1) * (h - f2)
            h = f2
    return float(hv)


def hv2d_contrib_min(F: np.ndarray, ref: np.ndarray) -> np.ndarray:
    hv_all = hv2d_min(F, ref)
    n = F.shape[0]
    if n == 0:
        return np.array([], dtype=float)
    contrib = np.array([hv_all - hv2d_min(np.delete(F, i, axis=0), ref) for i in range(n)], dtype=float)
    return contrib


# -----------------------------
# Safe normalization
# -----------------------------
def safe_norm(z, zmin, zmax):
    z = np.asarray(z, dtype=float)
    if (not np.isfinite(zmin)) or (not np.isfinite(zmax)) or np.isclose(zmax, zmin):
        return np.zeros_like(z)
    return (z - zmin) / (zmax - zmin)


# -----------------------------
# Gini coefficient for contribution concentration
# -----------------------------
def gini(x):
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size == 0:
        return np.nan
    x = np.sort(np.maximum(0.0, x))
    s = float(x.sum())
    if s <= 0:
        return 0.0
    n = x.size
    return float((2.0 * (np.arange(1, n + 1) * x).sum() / (n * s)) - (n + 1) / n)


