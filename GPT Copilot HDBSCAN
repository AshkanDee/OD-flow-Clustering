def get_dir_head(prep_city, n=6):
    """
    Try to find direction vectors in:
    1) X_scaled columns (if stored as DataFrame with column names)
    2) X columns (if stored as DataFrame with column names)
    3) city_clean columns
    Returns a small DataFrame head or None.
    """

    # 1) X_scaled (only if it's a DataFrame with column names)
    Xs = prep_city.get("X_scaled", None)
    if isinstance(Xs, pd.DataFrame):
        cn = list(Xs.columns)
        if all(c in cn for c in ["dx", "dy"]):
            return Xs.loc[:, ["dx", "dy"]].head(n)
        if all(c in cn for c in ["ux", "uy"]):
            return Xs.loc[:, ["ux", "uy"]].head(n)

    # 2) X (only if it's a DataFrame with column names)
    X = prep_city.get("X", None)
    if isinstance(X, pd.DataFrame):
        cn = list(X.columns)
        if all(c in cn for c in ["dx", "dy"]):
            return X.loc[:, ["dx", "dy"]].head(n)
        if all(c in cn for c in ["ux", "uy"]):
            return X.loc[:, ["ux", "uy"]].head(n)

    # 3) city_clean (most likely place in your pipeline)
    df = prep_city.get("city_clean", None)
    if isinstance(df, pd.DataFrame):
        cn = list(df.columns)
        if all(c in cn for c in ["ux", "uy"]):
            return df.loc[:, ["ux", "uy"]].head(n)
        if all(c in cn for c in ["dx", "dy"]):
            return df.loc[:, ["dx", "dy"]].head(n)

    return None

