import numpy as np

def eval_solution(labels,
                  u_trips,
                  noise_label=0,
                  min_cluster_size=2):
    """
    labels: 1D array-like (DBSCAN-style: noise=0, clusters=1..K)
    u_trips: Nx2 array with columns [ux, uy]
    returns: dict with f1/f2 + raw objectives + metadata
    """

    labels = np.asarray(labels, dtype=int)
    u_trips = np.asarray(u_trips, dtype=float)

    if u_trips.ndim != 2 or u_trips.shape[1] != 2:
        raise ValueError("eval_solution: u_trips must be an Nx2 array with columns [ux, uy]")

    N_total = int(labels.size)
    if N_total <= 0:
        raise ValueError("eval_solution: empty labels")

    if u_trips.shape[0] != N_total:
        raise ValueError("eval_solution: len(labels) must match nrow(u_trips)")

    clustered = (labels != noise_label) & np.isfinite(u_trips[:, 0]) & np.isfinite(u_trips[:, 1])
    n_clustered = int(clustered.sum())
    coverage = float(n_clustered / N_total)

    K = int(np.unique(labels[clustered]).size) if n_clustered > 0 else 0

    coh = dir_cohesion_within_weighted(
        labels=labels,
        u=u_trips,
        noise_label=noise_label,
        min_cluster_size=min_cluster_size,
        map_to_01=True
    )

    # NSGA-II minimizes => negate objectives
    f1 = 0.0 if coverage == 0 else -coverage     # in [-1, 0], worst = 0
    f2 = 0.0 if coverage == 0 else -float(coh)   # in [-1, 0], worst = 0

    return {
        "f1_neg_coverage": f1,
        "f2_neg_dir_cohesion": f2,
        "coverage": coverage,
        "dir_cohesion": float(coh),
        "K": K,
        "clustered_n": n_clustered,
        "N_total": N_total
    }


