# Step 11a — Size-weighted within-cluster directional cohesion
# Matches your R function exactly in logic:
# - remove noise + NA + invalid vectors
# - for each cluster: mean direction -> normalize -> mean cosine similarity
# - size-weighted average across clusters
# - optionally map [-1,1] to [0,1]
# ------------------------------------------------------------

def dir_cohesion_within_weighted(labels,
                                 u,
                                 noise_label=0,
                                 min_cluster_size=2,
                                 map_to_01=True):
    """
    labels: 1D array-like of cluster labels (DBSCAN-style: noise=0)
    u: Nx2 array with columns [ux, uy] (unit direction vectors; may include NaN)
    """

    labels = np.asarray(labels, dtype=int)
    u = np.asarray(u, dtype=float)

    if u.ndim != 2 or u.shape[1] != 2:
        raise ValueError("u must be an Nx2 array with columns [ux, uy]")

    ux = u[:, 0]
    uy = u[:, 1]

    ok = (~np.isnan(labels)) & (labels != noise_label) & np.isfinite(ux) & np.isfinite(uy)
    if not np.any(ok):
        return 0.0

    labels = labels[ok]
    ux = ux[ok]
    uy = uy[ok]

    cl_ids = np.unique(labels)
    if cl_ids.size == 0:
        return 0.0

    num = 0.0
    den = 0.0

    for cid in cl_ids:
        idx = (labels == cid)
        n = int(idx.sum())
        if n < int(min_cluster_size):
            continue

        mx = float(np.mean(ux[idx]))
        my = float(np.mean(uy[idx]))
        nm = np.sqrt(mx*mx + my*my)

        if (not np.isfinite(nm)) or (nm < 1e-12):
            continue

        mx /= nm
        my /= nm

        cos_i = ux[idx] * mx + uy[idx] * my
        cos_i = np.clip(cos_i, -1.0, 1.0)

        coh_c = float(np.mean(cos_i))

        num += n * coh_c
        den += n

    if den == 0:
        return 0.0

    coh = num / den  # in [-1, 1]
    return (coh + 1.0) / 2.0 if map_to_01 else coh


