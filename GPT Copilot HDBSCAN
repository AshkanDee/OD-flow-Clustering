def read_rds_as_df(rds_path: str) -> pd.DataFrame:
    if not os.path.exists(rds_path):
        raise FileNotFoundError(f"File not found: {rds_path}")

    res = pyreadr.read_r(rds_path)  # dict-like: {object_name: dataframe}
    if len(res.keys()) == 0:
        raise ValueError(f"No objects found inside RDS: {rds_path}")

    # typically only one object stored
    obj = next(iter(res.values()))
    if not isinstance(obj, pd.DataFrame):
        # pyreadr can return other types, but for this project we expect a data.frame/data.table
        raise TypeError(f"Expected a data.frame in {rds_path}, got: {type(obj)}")

    return obj


# ============================================================
# Step 0 function: prep_city_od
# ============================================================
def prep_city_od(
    rds_path: str,
    needed_cols=("start_loc_lon", "start_loc_lat", "dest_loc_lon", "dest_loc_lat"),
    crs_in: int = 4326,
    crs_out: int = 25832,
    drop_zero_len: bool = True
):
    """
    Python mirror of your R prep_city_od():
    - read .rds
    - check columns
    - drop NA
    - range filter lat/lon
    - transform to EPSG:25832 and add x_o,y_o,x_d,y_d
    - compute dx, dy, angle, len
    - optionally drop zero-length trips
    - return {"data": df, "info": info_dict}
    """

    dt = read_rds_as_df(rds_path).copy()

    # Column presence check
    missing = [c for c in needed_cols if c not in dt.columns]
    if missing:
        raise ValueError(f"Missing columns in {rds_path}: {', '.join(missing)}")

    n_before = len(dt)

    # Drop NA rows (same condition as R)
    dt = dt.dropna(subset=list(needed_cols))
    n_after_na = len(dt)

    # Range filter (same as R)
    dt = dt[
        (dt["start_loc_lat"].between(-90, 90)) &
        (dt["dest_loc_lat"].between(-90, 90)) &
        (dt["start_loc_lon"].between(-180, 180)) &
        (dt["dest_loc_lon"].between(-180, 180))
    ].copy()
    n_after_range = len(dt)

    # CRS transform: WGS84 lon/lat -> EPSG:25832 meters
    transformer = Transformer.from_crs(f"EPSG:{crs_in}", f"EPSG:{crs_out}", always_xy=True)

    # Origin XY
    x_o, y_o = transformer.transform(dt["start_loc_lon"].to_numpy(), dt["start_loc_lat"].to_numpy())
    # Destination XY
    x_d, y_d = transformer.transform(dt["dest_loc_lon"].to_numpy(), dt["dest_loc_lat"].to_numpy())

    dt["x_o"] = x_o
    dt["y_o"] = y_o
    dt["x_d"] = x_d
    dt["y_d"] = y_d

    # dx, dy, angle, len (same formulas)
    dt["dx"] = dt["x_d"] - dt["x_o"]
    dt["dy"] = dt["y_d"] - dt["y_o"]
    dt["angle"] = np.arctan2(dt["dy"].to_numpy(), dt["dx"].to_numpy())
    dt["len"] = np.sqrt(dt["dx"].to_numpy()**2 + dt["dy"].to_numpy()**2)

    n_zero_len = int((dt["len"] == 0).sum())

    if drop_zero_len:
        dt = dt[dt["len"] > 0].copy()

    n_after_zero = len(dt)

    info = {
        "file": rds_path,
        "n_before": n_before,
        "n_after_na": n_after_na,
        "n_after_range": n_after_range,
        "n_zero_len": n_zero_len,
        "n_after_zero": n_after_zero,
    }

    return {"data": dt, "info": info}


