def plot_knn_curves(city_id: str, k_values=k_values_dbscan, max_points=None):
    """
    Similar to your ggplot curve: sorted kNN distances.
    Use max_points to thin plotting for huge datasets (optional).
    """
    X_scaled = prepared[city_id]["X_scaled"]
    n = X_scaled.shape[0]

    if max_points is not None and n > max_points:
        # random subsample for plotting only (keeps curve shape roughly)
        rng = np.random.default_rng(1)
        idx = rng.choice(n, size=max_points, replace=False)
        Xp = X_scaled[idx, :]
    else:
        Xp = X_scaled

    plt.figure()
    for k in k_values:
        d = np.sort(knn_distances(Xp, k=k))
        plt.plot(np.arange(1, d.size + 1), d, label=f"k={k}", alpha=0.85)
    plt.title(f"kNN-distance curves — {city_id.upper()}")
    plt.xlabel("Points sorted by distance")
    plt.ylabel("kNN distance")
    plt.legend()
    plt.show()

